# ── Blank Five PDF Tools API — .htaccess ─────────────────────────
# CORS headers and PHP configuration for the API directory.

# PHP Upload Limits
php_value upload_max_filesize 50M
php_value post_max_size 55M
php_value max_execution_time 120
php_value memory_limit 256M

# Security: Prevent directory listing
Options -Indexes

# Security: Deny access to config files directly
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>
